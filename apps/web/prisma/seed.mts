async function main() {
  console.log(`Upserting ${points.length} points...`)
  for (const p of points) {
    await prisma.point.upsert({
      where: { slug: p.slug },
      update: {
        name: p.name,
        type: p.type,
        city: p.city,
        address: p.address,
        description: p.description ?? '',
        insertionType: p.insertionType ?? '',
        minimumInsertions: p.minimumInsertions ?? null,
        targetAudience: p.targetAudience ?? '',
        audienceClassification: p.audienceClassification ?? '',
        thumbnailUrl: p.thumbnailUrl ?? '',
        baseMediaUrl: p.baseMediaUrl ?? '',
        baseMediaType: p.baseMediaType ?? 'image',
        baseWidth: p.baseWidth ?? 0,
        baseHeight: p.baseHeight ?? 0,
        screenWidth: p.screenWidth ?? 0,
        screenHeight: p.screenHeight ?? 0,
        screenAspect: p.screenAspect ?? '16:9',
        fitMode: p.fitMode ?? 'cover',
        screenSelection: p.screenSelection ?? '{}',
        renderPreset: p.renderPreset ?? '{}',
        environmentType: p.environmentType ?? 'street',
        published: Boolean(p.published),
      },
      create: {
        id: p.id,
        slug: p.slug,
        name: p.name,
        type: p.type,
        city: p.city,
        address: p.address,
        description: p.description ?? '',
        insertionType: p.insertionType ?? '',
        minimumInsertions: p.minimumInsertions ?? null,
        targetAudience: p.targetAudience ?? '',
        audienceClassification: p.audienceClassification ?? '',
        thumbnailUrl: p.thumbnailUrl ?? '',
        baseMediaUrl: p.baseMediaUrl ?? '',
        baseMediaType: p.baseMediaType ?? 'image',
        baseWidth: p.baseWidth ?? 0,
        baseHeight: p.baseHeight ?? 0,
        screenWidth: p.screenWidth ?? 0,
        screenHeight: p.screenHeight ?? 0,
        screenAspect: p.screenAspect ?? '16:9',
        fitMode: p.fitMode ?? 'cover',
        screenSelection: p.screenSelection ?? '{}',
        renderPreset: p.renderPreset ?? '{}',
        environmentType: p.environmentType ?? 'street',
        published: Boolean(p.published),
      }
    })
  }
  console.log(`Done — ${points.length} points upserted.`)
}

main()
  .catch(e => { console.error(e); process.exit(1) })
  .finally(() => prisma.$disconnect())
